      found = teams.find { |t| t[0] == id }
      if found.nil?
        problems << "team #{id} is in the mapping but not in the database"
      elsif found[1] != expected
        problems << "team #{id} (#{found[2]}) is at ##{found[1]}, expected ##{expected}"
      end
    end

    teams.reject { |id, _, _| mapping.key?(id) }.each do |id, position, name|
      if position <= max_snapshot_position
        problems << "unmapped team #{id} (#{name}) at ##{position} occupies snapshot range"
      else
        puts "note: unmapped team #{id} (#{name}) at ##{position} registered after snapshot; leaving as-is"
      end
    end

    if problems.any?
      abort "ABORTING — live state doesn't match expectations:\n" + problems.map { |p| "  #{p}" }.join("\n")
    end

    changes = mapping.select { |_id, (current, target)| current != target }
    puts "verified #{mapping.size} teams; #{changes.size} numbers to restore"

    if ENV["APPLY"] == "1"
      Team.transaction do
        Team.unscoped.where(id: changes.keys).update_all("position = position + #{offset}")
        changes.each do |id, (_current, target)|
          Team.unscoped.where(id: id).update_all(position: target)
        end
      end

      positions = Team.unscoped.where(race_id: race_id).pluck(:position)
      duplicates = positions.tally.select { |_position, count| count > 1 }
      abort "POST-CHECK FAILED: duplicate positions #{duplicates.inspect}" if duplicates.any?
      mismatches = Team.unscoped.where(race_id: race_id, id: mapping.keys).pluck(:id, :position)
        .reject { |id, position| mapping[id][1] == position }
      abort "POST-CHECK FAILED: #{mismatches.inspect}" if mismatches.any?

      puts "restored #{changes.size} team numbers; post-checks passed"
    else
      changes.first(10).each do |id, (current, target)|
        puts "  would move team #{id}: ##{current} -> ##{target}"
      end
      puts "  ... and #{changes.size - 10} more"
      puts "DRY RUN — re-run with APPLY=1 to execute"
    end
  end
